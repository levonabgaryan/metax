# Template for .env. Copy to `.env` and fill in real values for prod.
#
# IMPORTANT:
# * DevConfigs IGNORES .env entirely - dev uses class-level defaults baked
#   into metax_configs.py and matches docker-compose.dev.yml. You do NOT need
#   .env for `ENV=dev`. Set `ENV=dev` in your shell or IDE run configuration.
# * TestConfigs also ignores .env. CI passes everything via Compose-level env
#   from docker-compose.test.yml.
# * ProdConfigs DOES read .env. All values below must be present and valid.

ENV=dev

# Backend / Django
DJANGO_SECRET_KEY=
DJANGO_SERVER_HOST=0.0.0.0
DJANGO_SERVER_PORT=8000

# PostgreSQL
POSTGRES_HOST=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=5432

# Redis
REDIS_SERVER_HOST=metax-redis
REDIS_PASSWORD=
REDIS_PORT=6379

# OpenSearch
OPENSEARCH_HOST=
OPENSEARCH_USERNAME=admin
OPENSEARCH_ADMIN_PASSWORD=
OPENSEARCH_NODE_PORT=

# Logging (fluent-bit)
FLUENT_BIT_HOST=
FLUENT_BIT_PORT=

# Log server
LOG_SERVER_HOST=
LOG_SERVER_PORT=
LOG_SERVER_USER=
LOG_SERVER_PASSWORD=
